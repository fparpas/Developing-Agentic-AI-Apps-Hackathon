# Challenge 08 Solution - Foundry Hosted Agent (Python)
# FOUNDRY_PROJECT_ENDPOINT and AZURE_AI_MODEL_DEPLOYMENT_NAME are injected automatically when the
# agent runs in Foundry. Set them here only for local testing.

FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Remote Weather MCP server endpoint from Challenge 4 / Challenge 6
WEATHER_MCP_ENDPOINT=https://<your-weather-mcp>.azurecontainerapps.io
